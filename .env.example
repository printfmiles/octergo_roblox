# App
NODE_ENV=development
APP_URL=http://localhost:5173
API_URL=http://localhost:3000

# Database (Supabase)
# Pooled connection — used by the API at runtime (Settings → Database → Connection string → URI, port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection — used by Prisma Migrate (Settings → Database → Connection string → URI, port 5432)
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Local Postgres alternative (if not using Supabase):
# DATABASE_URL=postgresql://postgres:password@localhost:5432/octergo
# DIRECT_URL=postgresql://postgres:password@localhost:5432/octergo

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me

# Internal bot authentication
BOT_INTERNAL_SECRET=replace_me

# Discord
DISCORD_CLIENT_ID=replace_me
DISCORD_PUBLIC_KEY=replace_me
DISCORD_BOT_TOKEN=replace_me
DISCORD_GUILD_ID=replace_me
DISCORD_VERIFY_CHANNEL_ID=replace_me
DISCORD_SESSION_CHANNEL_ID=replace_me
DISCORD_AUDIT_LOG_CHANNEL_ID=replace_me

# Roblox
ROBLOX_OPEN_CLOUD_API_KEY=replace_me

# Frontend
VITE_API_URL=http://localhost:3000
