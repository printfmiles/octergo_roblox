# App
NODE_ENV=development
APP_URL=http://localhost:5173
API_URL=http://localhost:3000

# ─── Supabase Postgres (single .env at repo root ONLY) ───
#
# Get both strings from: Supabase Dashboard → Settings → Database → Connection string
#
# DATABASE_URL — runtime (API / PrismaClient)
#   Transaction pooler: port 6543 + ?pgbouncer=true
#   Session pooler:     port 5432 on pooler host (no pgbouncer flag)
#
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
#
# DIRECT_URL — migrations only (pnpm db:migrate)
#   Use the direct host (db.<ref>.supabase.co), NOT the pooler
#
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Auth (generate random strings)
JWT_ACCESS_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me
BOT_INTERNAL_SECRET=replace_me

# Discord
DISCORD_CLIENT_ID=replace_me
DISCORD_PUBLIC_KEY=replace_me
DISCORD_BOT_TOKEN=replace_me
DISCORD_GUILD_ID=replace_me
DISCORD_VERIFY_CHANNEL_ID=replace_me
DISCORD_SESSION_CHANNEL_ID=replace_me
DISCORD_AUDIT_LOG_CHANNEL_ID=replace_me

# Roblox
ROBLOX_OPEN_CLOUD_API_KEY=replace_me

# Frontend
VITE_API_URL=http://localhost:3000
