{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@octergo/shared": ["packages/shared/src"],
      "@octergo/shared/*": ["packages/shared/src/*"],
      "@octergo/database": ["packages/database/src"],
      "@octergo/config": ["packages/config/src"]
    }
  }
}
