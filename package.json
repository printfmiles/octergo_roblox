{
  "name": "octergo-platform",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build:packages": "pnpm --filter @octergo/shared --filter @octergo/config build && pnpm db:generate && pnpm --filter @octergo/database build",
    "dev": "pnpm build:packages && dotenv -- pnpm --parallel dev",
    "dev:web": "dotenv -- pnpm --filter web dev",
    "dev:api": "dotenv -- pnpm --filter api dev",
    "dev:bot": "dotenv -- pnpm --filter bot dev",
    "db:migrate": "dotenv -- pnpm --filter database prisma migrate dev",
    "db:generate": "dotenv -- pnpm --filter database prisma generate",
    "db:seed": "dotenv -- pnpm --filter database prisma db seed",
    "bot:deploy-commands": "dotenv -- tsx scripts/deploy-commands.ts",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "discord.js": "^14.21.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
